#!/usr/bin/expect -f
# Drives an interactive `claude` session to read /usage output.
#
# Safety: NEVER pass --dangerously-skip-permissions. /usage is a slash command
# that doesn't invoke tool use, so we don't need that flag — and not passing it
# limits the blast radius if anything in this script goes sideways.
#
# Usage: fetch-quota.exp <path-to-claude>

log_user 1
set timeout 20

if {$argc < 1} {
    puts stderr "usage: fetch-quota.exp <claude-path>"
    exit 2
}
set claude [lindex $argv 0]

# Spawn under a pty so claude renders its TUI.
spawn -noecho $claude

# Some directories trigger a workspace-trust dialog on first run.
# Option 1 (Yes, trust) is pre-selected; send Enter to confirm.
# Skip silently after 3s if no dialog appears.
set timeout 3
expect {
    -re {trust|Trust} {
        send "\r"
        sleep 2
    }
    timeout {}
}

# Trigger /usage, give the panel time to render, then quit cleanly.
set timeout 20
send "/usage\r"
sleep 6
send "\x1b"
sleep 1
send "/exit\r"
expect eof
